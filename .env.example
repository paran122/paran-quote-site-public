# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin
ADMIN_PASSWORD=your-admin-password
ADMIN_SESSION_SECRET=your-32-char-random-secret

# Resend (이메일 알림)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_ADMIN_EMAIL=admin@yourdomain.com

# NCP SENS (카카오 알림톡)
NCP_ACCESS_KEY=your-ncp-access-key
NCP_SECRET_KEY=your-ncp-secret-key
NCP_SENS_SERVICE_ID=your-sens-service-id
NCP_KAKAO_PLUS_FRIEND_ID=your-kakao-plus-friend-id

# Claude API (AI 블로그 생성)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Site
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
INDEXNOW_KEY=your-indexnow-key
